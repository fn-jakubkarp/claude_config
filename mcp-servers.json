{
  "filesystem": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-filesystem",
      "$HOME/"
    ],
    "env": {}
  },
  "magic": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@21st-dev/magic@latest"
    ],
    "env": {
      "API_KEY": "${MAGIC_API_KEY}"
    }
  },
  "sequential-thinking": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "@modelcontextprotocol/server-sequential-thinking"
    ],
    "env": {}
  },
  "fetch": {
    "type": "stdio",
    "command": "uvx",
    "args": [
      "mcp-server-fetch"
    ],
    "env": {}
  }
}
